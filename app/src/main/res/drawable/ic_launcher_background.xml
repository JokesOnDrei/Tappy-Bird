<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon background. A subtle vertical sky gradient (light → mid)
    matching the in-game sky color (rgb 112, 197, 206) for visual continuity
    with the splash and gameplay screens.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0" android:startY="0"
                android:endX="0" android:endY="108"
                android:type="linear">
                <item android:offset="0.0" android:color="#A4DEEE" />
                <item android:offset="1.0" android:color="#70C5CE" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
