<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground: the pixel-art bird from BirdSprite, expressed
    as a vector drawable. Each cell of the 17x12 sprite grid is a 4dp
    rectangle; all rectangles of the same color are merged into a single
    <path> with multiple "M x y h w v 4 h -w Z" sub-segments — six paths
    total (one per palette color).

    Sprite is centered at (54, 54): 17 cols * 4dp = 68dp wide, 12 rows * 4dp =
    48dp tall, top-left at (20, 30). Comfortably inside the 72dp safe zone
    of an adaptive icon — no clipping under round / squircle masks.

    Hand-derived from BirdSprite.GRID — keep the two in sync if you change
    the sprite. Color codes:
       B = #2B1C10 outline      Y = #FCDC5A yellow body
       W = #FFFFFF white        O = #FFA532 orange beak
       R = #DC463C red wing     r = #FA6E5F red wing highlight
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Yellow body -->
    <path
        android:fillColor="#FCDC5A"
        android:pathData="
            M36,34 h20 v4 h-20 Z
            M32,38 h16 v4 h-16 Z
            M32,42 h16 v4 h-16 Z
            M28,46 h20 v4 h-20 Z
            M28,50 h20 v4 h-20 Z
            M40,54 h12 v4 h-12 Z
            M36,58 h24 v4 h-24 Z
            M60,62 h8  v4 h-8  Z
            M64,66 h4  v4 h-4  Z" />

    <!-- White (eye + belly highlight) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M56,34 h4  v4 h-4  Z
            M60,38 h4  v4 h-4  Z
            M52,42 h12 v4 h-12 Z
            M68,42 h4  v4 h-4  Z
            M52,46 h4  v4 h-4  Z
            M60,46 h4  v4 h-4  Z
            M52,50 h12 v4 h-12 Z
            M28,54 h12 v4 h-12 Z
            M24,58 h8  v4 h-8  Z
            M24,62 h4  v4 h-4  Z" />

    <!-- Orange beak -->
    <path
        android:fillColor="#FFA532"
        android:pathData="
            M72,46 h12 v4 h-12 Z
            M68,50 h16 v4 h-16 Z
            M68,54 h16 v4 h-16 Z
            M68,58 h12 v4 h-12 Z" />

    <!-- Red wing -->
    <path
        android:fillColor="#DC463C"
        android:pathData="
            M32,62 h24 v4 h-24 Z
            M32,66 h4  v4 h-4  Z
            M56,66 h4  v4 h-4  Z
            M32,70 h28 v4 h-28 Z" />

    <!-- Red wing highlight -->
    <path
        android:fillColor="#FA6E5F"
        android:pathData="M36,66 h20 v4 h-20 Z" />

    <!-- Dark outline + pupil (drawn last so it sits on top of all fills) -->
    <path
        android:fillColor="#2B1C10"
        android:pathData="
            M36,30 h24 v4 h-24 Z
            M32,34 h4  v4 h-4  Z
            M60,34 h8  v4 h-8  Z
            M28,38 h4  v4 h-4  Z
            M48,38 h12 v4 h-12 Z
            M64,38 h8  v4 h-8  Z
            M28,42 h4  v4 h-4  Z
            M48,42 h4  v4 h-4  Z
            M64,42 h4  v4 h-4  Z
            M72,42 h4  v4 h-4  Z
            M24,46 h4  v4 h-4  Z
            M48,46 h4  v4 h-4  Z
            M56,46 h4  v4 h-4  Z
            M64,46 h8  v4 h-8  Z
            M84,46 h4  v4 h-4  Z
            M24,50 h4  v4 h-4  Z
            M48,50 h4  v4 h-4  Z
            M64,50 h4  v4 h-4  Z
            M84,50 h4  v4 h-4  Z
            M24,54 h4  v4 h-4  Z
            M52,54 h16 v4 h-16 Z
            M84,54 h4  v4 h-4  Z
            M20,58 h4  v4 h-4  Z
            M32,58 h4  v4 h-4  Z
            M60,58 h8  v4 h-8  Z
            M80,58 h4  v4 h-4  Z
            M20,62 h4  v4 h-4  Z
            M28,62 h4  v4 h-4  Z
            M56,62 h4  v4 h-4  Z
            M68,62 h8  v4 h-8  Z
            M24,66 h8  v4 h-8  Z
            M60,66 h4  v4 h-4  Z
            M68,66 h4  v4 h-4  Z
            M24,70 h8  v4 h-8  Z
            M60,70 h8  v4 h-8  Z
            M28,74 h36 v4 h-36 Z" />
</vector>
